NEXT_PUBLIC_APP_URL=https://klipio.io
NODE_ENV=development

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=klipio-videos
R2_PUBLIC_URL=https://cdn.klipio.io

VPS_HOST=your_vps_host
VPS_PORT=22
VPS_USER=klipio
VPS_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
YOUR_PRIVATE_KEY
-----END OPENSSH PRIVATE KEY-----"
VPS_SSH_PASSPHRASE=
YTDLP_PATH=/usr/local/bin/yt-dlp
FFPROBE_PATH=/usr/bin/ffprobe
FFMPEG_PATH=/usr/bin/ffmpeg

PROXY_PRIMARY_URL=http://user:pass@proxy-host:port
PROXY_BACKUP_URLS=
PROXY_USERNAME=
PROXY_PASSWORD=

RATE_LIMIT_ANONYMOUS=10
RATE_LIMIT_REGISTERED=100
RATE_LIMIT_WINDOW_MS=3600000

WORKER_SECRET=replace_with_a_long_random_secret
CRON_SECRET=replace_with_a_long_random_secret
MAX_WORKER_JOBS_PER_INVOCATION=1

ENABLE_ANALYSIS=false
ENABLE_TIKTOK=true
ENABLE_INSTAGRAM=true
ENABLE_FACEBOOK=true
ENABLE_YOUTUBE=true
ENABLE_TWITTER=true

OPENROUTER_API_KEY=
DEEPGRAM_API_KEY=
LOG_LEVEL=info
SENTRY_DSN=
