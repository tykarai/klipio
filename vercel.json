{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "klipio",
  "version": 2,

  "buildCommand": "next build",
  "devCommand": "next dev --turbopack",
  "installCommand": "npm install",

  "framework": "nextjs",
  "outputDirectory": ".next",

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],

  "crons": [
    {
      "path": "/api/worker/process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/recover-jobs",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/cleanup-expired",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-r2",
      "schedule": "30 * * * *"
    }
  ],

  "env": {
    "NEXT_PUBLIC_APP_URL": "https://klipio.io"
  }
}
